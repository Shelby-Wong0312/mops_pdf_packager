            <main id="main">
                <div class="page-head">
                    <div class="page-head-banner wow fadeIn">
                        <div class="banner-pic imgFill">
                            <img src="/files/responsibility/responsibility/banner.jpg" alt="" />
                        </div>
                    </div>
                    <div class="page-head-main">
                        <div class="page-head-bread container extra-large wow fadeInUp">
                            <ul class="noneStyle">
                                <li><a href="/">首頁</a></li>
                                <li><a href="/responsibility01">ESG永續發展</a></li>
