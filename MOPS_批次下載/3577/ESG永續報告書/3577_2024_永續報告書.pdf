                    //pushFixedHeight(fixedBox);
                });


                //if($(window).width() < 768){
                    //if (fixedBox.hasClass("mobile-animate")) {
                        //偵測滑動方向
                        var lastScrollTop = 0;
                        $(window).scroll(function (event) {
                            var st = $(this).scrollTop();
                            if (st > lastScrollTop) {
                                //fixedBox.addClass("down");
                                wrapbody.addClass("nav-down");
                            } else {
                                //fixedBox.removeClass("down");
