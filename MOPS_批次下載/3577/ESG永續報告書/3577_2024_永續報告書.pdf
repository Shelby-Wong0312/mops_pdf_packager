            if ($( ".header .navbar-collapse").hasClass( "in" ) ) {
                $(this).parent().find('.navbar').css("position","relative");
            }

            $('[data-toggle="tooltip"]').tooltip()



			var NavProBox = $('.header .NavProBox'); 
            var Nav2 = $('.header .nav2');
            $(window).scroll(function (e) {
                var win_h = $(window).scrollTop();
                var win_w = $(window).width();
				// 視窗捲動超過.header時，#floating 增加.fixed
                var page_w = $(".main_content > .container").width();
                var floating_offset_top = $(".header").height() + $(".main_top").height();
                if (win_h > floating_offset_top) {
                    $("#floating").addClass("fixed");
                } else {
                    $("#floating").removeClass("fixed");
                }
                (win_h > 10) ? $("body").addClass("is_scroll") : $("body").removeClass("is_scroll");
				//console.log('win_h2='+win_h);
                if($("body").hasClass("product show")){                
					//
                }else if($("body").hasClass("member profile")){
                    var Nav2HasClass = Nav2.hasClass("navbar-fixed-top");
                    if(win_h >= $(".navbar").height()){     
                        if(!Nav2HasClass){
                            Nav2.addClass("navbar-fixed-top");
                        }                    
                    }else{
                        if(Nav2HasClass){
                            Nav2.removeClass("navbar-fixed-top");
                        }                 
                    }
                }
            });




            //側選單的開合按鈕
            $('.side-toggle').click(function (e) {
                e.preventDefault();
                $('.side').toggleClass("menu-open");
            });
            //gotop Animate
			//$(".gotop").on('click', 'a[href^="#"]', function () {
			//	$("html,body").animate({ scrollTop: 0 }, 600);
            //    return false;
			//});

            $(".gotop a").click(function (e) {
                e.preventDefault();
				$("html,body").animate({ scrollTop: 0 }, 600);
			});

            ResizeMethod();

            /*日期選擇器*/
            $(".datepicker").datepicker().on('changeDate', function (e) {
                $(this).datepicker('hide');
            });
            $('.datepicker').css("cursor", "pointer");
             
             
             //header
