					<script type="text/javascript">
						function epaperOrder(){
							$('#epaper_type').val('order');
							epaperSubmit();
						} 
						function epaperCancel(){
							$('#epaper_type').val('cancel');
							epaperSubmit();
						}
						function epaperSubmit(){
							if ($('#epaper_email').val()==""){
								alert('E-mail is required field.');
								$('#epaper_email').focus();							
							}else if (!(/^\w+([\.-]?\w+)*@\w+([\.-]?\w+)*(\.\w{2,3})+$/.test($('#epaper_email').val()))){ 
								alert('Incorrect e-mail format.');
								$('#epaper_email').focus();							
							}else{
							
								if ($('#epaper_type').val()=='order') {
									$.ajax({
										type: "POST",
										url: "/epaper.php",
										cache: false,
										data: { email: $('#epaper_email').val(), type: $('#epaper_type').val(), nation:'TW' }
									}).done(function( msg ) {  								
										alert(msg);								
									});
								} else {
									top.window.location="/tw/contact/unsubscribe.php?rtn=%2Ftw%2Fcsr%2Findex.php%3Fkind%3D71&email="+$('#epaper_email').val();
								}
														
							}						
						}
					</script>
                    <div class="input-group hidden">
                        <input type="text" class="form-control" placeholder="Subscribe our enews" id="epaper_email" name="epaper_email">
						<input id="epaper_type" name="epaper_type" type="hidden" value="order" />
                        <!-- <a href="javascript:epaperOrder()" class="input-group-addon">SEND</a> -->
						<a href="javascript:epaperCancel()" class="input-group-addon  btn-unsubscribe">取消</a>                        
                    </div>
                </div>

			</div>
			
