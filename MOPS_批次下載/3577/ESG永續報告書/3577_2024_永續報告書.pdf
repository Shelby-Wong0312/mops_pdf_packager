    <script type="text/javascript">
    
        $(document).ready(function () {

            //check ie
            if ($.browser.msie && $.browser.version <= "8.0") {
                $('body').addClass('is_oldie');
                // please upgrade your browser
            }
            if (Modernizr.touch) {
                $("body").addClass("is_touch");
