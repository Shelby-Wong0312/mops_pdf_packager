<script>
$(function() {
	jQuery("#keyword").autocomplete({
		minLength: 3,
		source: function(request, response) { 
			jQuery.ajax({
				url: "/tw/_include/search_json.php",
				data: {
					kw : request.term, is_home : 'false'
				},
				dataType: "json",
				success: function(data) 	{
					response(data);
				}	
			})
	 	},
		html: true,
        select: function (event, ui) {            
            if (ui.item.link != null){
                window.location = ui.item.link;
            } else {
                window.location = "/tw/product/show.php?num=" + ui.item.pro_id;
            }
        }
	}).autocomplete("instance")._renderItem = function (ul, item) {
    return $("<li>")
        .append("<div><a href='" + ((item.link!=null)?item.link:"/tw/product/show.php?num=" +  + item.pro_id) + "'>Module: " + item.value + "<br />Info: " + item.label + "</a></div>")
        .appendTo(ul);
	};
});

function nav_search(){													 				   
	if ($('#keyword').val()==""){
		alert("請輸入關鍵字!");
		return false;
	}
	return true;
}

$(function() {
	jQuery("#t").autocomplete({
		minLength: 2,
		source: function(request, response) { 
			jQuery.ajax({
				url: "/tw/_include/search_tags_json.php",
				data: {
					kw : request.term
				},
				dataType: "json",
				success: function(data) 	{
					response(data);
				}	
			})
	 	},
		html: true,
        select: function (event, ui) {
            if (ui.item.value != null){
                window.location = "/tw/search/result.php?t=" + ui.item.value;
            }
        }
	}).autocomplete("instance")._renderItem = function (ul, item) {
    return $("<li>")
        .append("<div><a href='" + ("/tw/search/result.php?t=" + item.value) + "'>" + item.value + "</a></div>")
        .appendTo(ul);
	};
});

function tag_search(){													 				   
	if ($('#t').val()==""){
		alert("請輸入標籤!");
		return false;
	}
	return true;
}
</script>
